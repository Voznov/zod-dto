{
  "name": "@voznov/zod-dto",
  "version": "0.1.0",
  "description": "Framework-agnostic ZodDto factory — turn Zod schemas into validatable DTO classes",
  "author": "Petr Voznov",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist", "LICENSE", "NOTICE"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "zod": ">=4.0.0"
  }
}
