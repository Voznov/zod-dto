{
  "name": "@voznov/zod-dto",
  "version": "0.1.3",
  "description": "Framework-agnostic ZodDto factory — turn Zod schemas into validatable DTO classes",
  "keywords": ["zod", "dto", "validation", "typescript", "schema", "class"],
  "author": "Petr Voznov",
  "license": "Apache-2.0",
  "homepage": "https://github.com/Voznov/zod-dto/tree/master/packages/core#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Voznov/zod-dto.git",
    "directory": "packages/core"
  },
  "bugs": "https://github.com/Voznov/zod-dto/issues",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist", "LICENSE", "NOTICE"],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "zod": ">=4.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
